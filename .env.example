# App
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Supabase - usar Project URL e Publishable Key no client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase - server only. Nunca expor no client.
# Para projetos antigos, pode ser service_role. Para projetos novos, pode ser secret key.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# Banco direto apenas para scripts locais/CI, se necessário. Não usar no browser.
DATABASE_URL=

# E-mail provider - escolher um na implementação
BREVO_API_KEY=
RESEND_API_KEY=
EMAIL_FROM=no-reply@seudominio.com

# Jobs/cron
CRON_SECRET=

# Observabilidade
SENTRY_DSN=

# Feature flags iniciais
NEXT_PUBLIC_ENABLE_DEBUG_UI=false
